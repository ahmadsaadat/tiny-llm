                <mxCell id="65" value="&lt;b&gt;3 random matrices:&lt;br&gt;&lt;br&gt;&lt;/b&gt;&lt;div&gt;W_Q = (embedding_dimension, embedding_dimension) (4, 4)&lt;br&gt;W_K = (embedding_dimension, embedding_dimension)&amp;nbsp;&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;(4, 4)&lt;/span&gt;&lt;br&gt;W_V = (embedding_dimension, embedding_dimension)&amp;nbsp;&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;(4, 4)&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;--------------------------------&lt;/span&gt;&lt;span style=&quot;scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); color: rgb(63, 63, 63);&quot;&gt;--------------------------------&lt;/span&gt;&lt;span style=&quot;scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); color: rgb(63, 63, 63);&quot;&gt;--------------&lt;/span&gt;&lt;br&gt;&lt;b&gt;X&lt;/b&gt; = embedding_table[token_ids] (2, 4)&lt;br&gt;--------------------------------&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;--------------------------------&lt;/span&gt;&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;--------------&lt;/span&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot;&gt;Q = X @ W_Q&amp;nbsp; = &quot;What am I looking for?&quot; (2, 4)&lt;br&gt;K = X @ W_K&amp;nbsp; &amp;nbsp;= &quot;What information do I contain?&quot; (2, 4)&lt;/div&gt;&lt;div&gt;V = X @ W_V&amp;nbsp; &amp;nbsp;= &quot;What do I carry forward?&quot; (2, 4)&lt;/div&gt;" style="whiteSpace=wrap;html=1;rounded=1;align=left;spacingLeft=10;" parent="1" vertex="1">
